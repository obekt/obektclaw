# obektclaw Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# LLM Configuration (required)
# =============================================================================
# Any OpenAI-compatible endpoint works:
#   - OpenAI: https://api.openai.com/v1
#   - OpenRouter: https://openrouter.ai/api/v1
#   - Ollama: http://localhost:11434/v1
#   - vLLM: http://localhost:8000/v1
#   - Dashscope: https://dashscope.aliyuncs.com/compatible-mode/v1

OBEKTCLAW_LLM_BASE_URL=https://openrouter.ai/api/v1
OBEKTCLAW_LLM_API_KEY=your-api-key-here

# Main model for reasoning and tool use
OBEKTCLAW_LLM_MODEL=anthropic/claude-haiku-4.5

# Fast/cheap model for Learning Loop retrospection
OBEKTCLAW_LLM_FAST_MODEL=anthropic/claude-haiku-4.5


# =============================================================================
# Storage Configuration (optional)
# =============================================================================
# Where memory, skills, and logs are stored
# Default: ~/.obektclaw
# Leave empty to use default

OBEKTCLAW_HOME=

# Context window size in tokens (optional)
# Default: 0 (auto-detect from model name)
# Set to override automatic detection
# Examples: gpt-4o=128000, claude-3=200000, qwen3=32768

OBEKTCLAW_CONTEXT_WINDOW=0


# =============================================================================
# Telegram Bot (optional)
# =============================================================================
# Get token from @BotFather on Telegram
# Leave empty to disable Telegram gateway

OBEKTCLAW_TG_TOKEN=
OBEKTCLAW_TG_ALLOWED_CHAT_IDS=


# =============================================================================
# Tool Execution (optional)
# =============================================================================
# Timeout for bash commands (seconds)
# Default: 30

OBEKTCLAW_BASH_TIMEOUT=30

# Working directory for bash/exec_python tools
# Default: current directory
# Use absolute paths for security

OBEKTCLAW_WORKDIR=
